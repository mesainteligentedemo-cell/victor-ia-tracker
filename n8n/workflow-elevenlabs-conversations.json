    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst body = raw.body || raw;\nconst type = body.type || '';\nconst now = new Date().toISOString();\n\n// Solo procesar formularios del widget; ignorar webhooks automáticos de ElevenLabs\nif(type !== 'contact_form' && !type.startsWith('form_')) return [];\n\nconst nombre          = body.nombre    || '';\nconst email           = body.email     || '';\nconst whatsapp        = body.whatsapp  || '';\nconst canal           = body.canal     || 'web';\nconst conv_id         = body.elevenlabs_conversation_id || '';\nconst slug            = body.slug      || '';\nconst source_url      = body.source_url  || '';\nconst page_title      = body.page_title  || '';\nconst duracion_seg    = body.duracion_conversacion_seg != null ? Number(body.duracion_conversacion_seg) : null;\nconst tiempo_pagina_seg = body.tiempo_en_pagina_seg   != null ? Number(body.tiempo_en_pagina_seg)      : null;\nconst scroll_pct      = body.scroll_depth_pct         != null ? Number(body.scroll_depth_pct)          : null;\nconst visita_num      = body.visita_num || 1;\nconst transcript_texto = (body.transcript || '').slice(0, 5000);\nconst fecha           = (body.ts || now).split('T')[0];\nconst hora            = (body.ts || now).split('T')[1]?.slice(0, 5) || now.split('T')[1].slice(0, 5);\n\nconst durStr  = duracion_seg      != null ? String(duracion_seg)      + ' s' : '';\nconst tieStr  = tiempo_pagina_seg != null ? String(tiempo_pagina_seg) + ' s' : '';\nconst scrlStr = scroll_pct        != null ? String(scroll_pct)        + '%'  : '';\n\nreturn [{\n  json: {\n    type, nombre, email, whatsapp, canal, conv_id,\n    slug, source_url, page_title,\n    visita_num: String(visita_num),\n    duracion_seg, tiempo_pagina_seg, scroll_pct,\n    durStr, tieStr, scrlStr,\n    transcript_texto,\n    transcript_para_resumen: transcript_texto.slice(0, 3000),\n    fecha, hora,\n    conversation_id: conv_id,\n    agent_id:   body.agent_id || '',\n    empresa:    body.empresa  || '',\n    duracion_min: duracion_seg != null ? Math.round(duracion_seg / 60) : 0,\n    num_mensajes: transcript_texto ? transcript_texto.split('\\n').filter(Boolean).length : 0,\n    estado_conv: body.status || 'completed'\n  }\n}];"
      },
