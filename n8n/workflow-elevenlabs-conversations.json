        "jsonBody": "={\n  \"model\": \"openai/gpt-4o-mini\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Analiza esta conversacion de ventas y responde en JSON exacto con estos campos: {\\\"resumen\\\": \\\"1-2 oraciones\\\", \\\"necesidad\\\": \\\"que necesita el cliente\\\", \\\"presupuesto\\\": \\\"monto o rango mencionado o null\\\", \\\"urgencia\\\": \\\"alta/media/baja\\\", \\\"interes\\\": \\\"alto/medio/bajo\\\", \\\"siguiente_paso\\\": \\\"accion recomendada\\\", \\\"calificacion\\\": \\\"MQL/SQL/No calificado\\\"}\\n\\nTranscript:\\n{{ $json.transcript_para_resumen }}\"\n    }\n  ],\n  \"max_tokens\": 400,\n  \"temperature\": 0.3\n}",
        "options": {}
      },
      "id": "b2c3d4e5-0003-0003-0003-000000000003",
      "name": "IA — Analizar Conversacion",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        700,
        480
      ]
    },
    {
      "parameters": {
        "jsCode": "const convData = $('Extraer Datos Conversacion').first().json;\nconst aiResponse = $input.first().json;\n\nlet analisis = {};\ntry {\n  const content = aiResponse.choices?.[0]?.message?.content || '{}';\n  const jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) analisis = JSON.parse(jsonMatch[0]);\n} catch(e) {\n  analisis = { resumen: 'No se pudo analizar', calificacion: 'Revisar manual' };\n}\n\nreturn [{\n  json: {\n    ...convData,\n    resumen_ia:        analisis.resumen        || '',\n    necesidad_ia:      analisis.necesidad       || '',\n    presupuesto_ia:    analisis.presupuesto     || '',\n    urgencia_ia:       analisis.urgencia        || 'media',\n    interes_ia:        analisis.interes         || 'medio',\n    siguiente_paso_ia: analisis.siguiente_paso  || '',\n    calificacion_ia:   analisis.calificacion    || 'No calificado',\n    crear_contacto: !!(convData.email || convData.nombre),\n    es_mql: analisis.calificacion === 'MQL' || analisis.calificacion === 'SQL',\n    nota_hubspot: `[Victor IA] ${convData.fecha} ${convData.hora}\\nResumen: ${analisis.resumen}\\nNecesidad: ${analisis.necesidad}\\nCalificacion: ${analisis.calificacion}\\nSiguiente: ${analisis.siguiente_paso}\\n\\nTranscript:\\n${convData.transcript_texto.slice(0,1000)}`\n  }\n}];"
      },
