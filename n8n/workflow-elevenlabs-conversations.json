        "emailType": "html",
        "html": "=<style>@import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@1,300;1,400&family=Space+Grotesk:wght@300;400;500;600&display=swap');</style>\n<body style=\"margin:0;padding:0;background:#F8F7F5;font-family:'Space Grotesk',Arial,sans-serif;-webkit-font-smoothing:antialiased;\">\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#F8F7F5;\"><tr><td align=\"center\" style=\"padding:48px 16px 64px;\">\n<table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:600px;width:100%;\">\n\n<!-- ══ HERO ══ -->\n<tr><td style=\"background:#0E0F12;padding:52px 52px 48px;text-align:center;\">\n\n  <!-- Logo -->\n  <img src=\"https://victor-ia-website.vercel.app/assets/brand/logo-full.png\" width=\"148\" style=\"display:block;margin:0 auto 44px;max-width:148px;\" alt=\"VICTOR IA\">\n\n  <!-- Badge -->\n  <table cellpadding=\"0\" cellspacing=\"0\" style=\"margin:0 auto 32px;\"><tr><td style=\"border:1px solid rgba(255,170,23,0.3);padding:7px 24px;\">\n    <span style=\"font-family:'Space Grotesk',Arial,sans-serif;color:rgba(255,170,23,0.75);font-size:8px;font-weight:600;letter-spacing:0.45em;text-transform:uppercase;\">Confirmaci&oacute;n de contacto</span>\n  </td></tr></table>\n\n  <!-- Heading -->\n  <h1 style=\"margin:0 0 20px;font-family:'Fraunces',Georgia,serif;font-size:40px;font-weight:300;font-style:italic;color:#F8F7F5;line-height:1.1;letter-spacing:-0.02em;\">{{ $json.nombre ? $json.nombre.split(' ')[0] : 'Hola' }}, tu mensaje<br><em style=\"color:#FFAA17;font-style:italic;\">lleg&oacute; con &eacute;xito.</em></h1>\n\n  <!-- Subtitle -->\n  <p style=\"margin:0;font-family:'Space Grotesk',Arial,sans-serif;font-size:13px;font-weight:300;color:rgba(248,247,245,0.38);line-height:1.9;letter-spacing:0.01em;\">Hemos recibido tu informaci&oacute;n y nuestro equipo<br>ya est&aacute; revisando los detalles de tu proyecto.</p>\n\n</td></tr>\n\n<!-- Línea oro -->\n<tr><td style=\"height:1px;background:#FFAA17;font-size:0;line-height:0;\">&nbsp;</td></tr>\n\n<!-- ══ CUERPO ══ -->\n<tr><td style=\"background:#ffffff;padding:56px 52px 48px;\">\n\n  <!-- Eyebrow -->\n  <p style=\"margin:0 0 14px;font-family:'Space Grotesk',Arial,sans-serif;font-size:8px;font-weight:600;color:#FFAA17;letter-spacing:0.45em;text-transform:uppercase;\">Lo que sigue</p>\n\n  <!-- Subtítulo editorial -->\n  <h2 style=\"margin:0 0 44px;font-family:'Fraunces',Georgia,serif;font-size:24px;font-weight:300;font-style:italic;color:#0E0F12;line-height:1.3;letter-spacing:-0.01em;\">Un especialista de Victor IA<br>se comunicar&aacute; contigo pronto.</h2>\n\n  <!-- Pasos -->\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:48px;\">\n\n    <tr><td style=\"padding:22px 0;border-bottom:1px solid rgba(14,15,18,0.07);\">\n      <table cellpadding=\"0\" cellspacing=\"0\"><tr>\n        <td style=\"width:30px;vertical-align:top;padding-top:0;\">\n          <span style=\"font-family:'Fraunces',Georgia,serif;font-size:28px;font-style:italic;font-weight:300;color:#FFAA17;line-height:1;\">1</span>\n        </td>\n        <td style=\"padding-left:22px;font-family:'Space Grotesk',Arial,sans-serif;font-size:13px;font-weight:300;color:rgba(14,15,18,0.5);line-height:1.8;\">\n          Nuestro equipo <strong style=\"color:#0E0F12;font-weight:600;\">analiza tu caso con IA</strong> para personalizar la propuesta perfecta para ti.\n        </td>\n      </tr></table>\n    </td></tr>\n\n    <tr><td style=\"padding:22px 0;border-bottom:1px solid rgba(14,15,18,0.07);\">\n      <table cellpadding=\"0\" cellspacing=\"0\"><tr>\n        <td style=\"width:30px;vertical-align:top;padding-top:0;\">\n          <span style=\"font-family:'Fraunces',Georgia,serif;font-size:28px;font-style:italic;font-weight:300;color:#FFAA17;line-height:1;\">2</span>\n        </td>\n        <td style=\"padding-left:22px;font-family:'Space Grotesk',Arial,sans-serif;font-size:13px;font-weight:300;color:rgba(14,15,18,0.5);line-height:1.8;\">\n          Te contactamos en <strong style=\"color:#0E0F12;font-weight:600;\">menos de 24 horas</strong> con una estrategia hecha a la medida de tu negocio.\n        </td>\n      </tr></table>\n    </td></tr>\n\n    <tr><td style=\"padding:22px 0;\">\n      <table cellpadding=\"0\" cellspacing=\"0\"><tr>\n        <td style=\"width:30px;vertical-align:top;padding-top:0;\">\n          <span style=\"font-family:'Fraunces',Georgia,serif;font-size:28px;font-style:italic;font-weight:300;color:#FFAA17;line-height:1;\">3</span>\n        </td>\n        <td style=\"padding-left:22px;font-family:'Space Grotesk',Arial,sans-serif;font-size:13px;font-weight:300;color:rgba(14,15,18,0.5);line-height:1.8;\">\n          Juntos definimos c&oacute;mo la <strong style=\"color:#0E0F12;font-weight:600;\">inteligencia artificial puede multiplicar</strong> los resultados de tu empresa.\n        </td>\n      </tr></table>\n    </td></tr>\n\n  </table>\n\n  <!-- CTA Principal -->\n  <a href=\"https://victor-ia-website.vercel.app/agenda\" style=\"display:block;background:#0E0F12;color:#F8F7F5;text-align:center;padding:20px 24px;font-family:'Space Grotesk',Arial,sans-serif;font-size:9px;font-weight:600;letter-spacing:0.28em;text-transform:uppercase;text-decoration:none;margin-bottom:10px;\">Agenda tu diagn&oacute;stico gratuito &nbsp;&nbsp;&rarr;</a>\n\n  <!-- CTA Secundario -->\n  <a href=\"https://wa.me/5219842353159\" style=\"display:block;background:#F8F7F5;border:1px solid rgba(14,15,18,0.15);color:#0E0F12;text-align:center;padding:19px 24px;font-family:'Space Grotesk',Arial,sans-serif;font-size:9px;font-weight:500;letter-spacing:0.22em;text-transform:uppercase;text-decoration:none;\">Continuar por WhatsApp &nbsp;&nbsp;&rarr;</a>\n\n</td></tr>\n\n<!-- ══ CITA ══ -->\n<tr><td style=\"background:#0E0F12;padding:56px 52px 48px;text-align:center;\">\n  <p style=\"margin:0 0 28px;font-family:'Fraunces',Georgia,serif;font-size:21px;font-style:italic;font-weight:300;color:#F8F7F5;line-height:1.6;letter-spacing:-0.01em;\">&ldquo;La inteligencia artificial no reemplaza<br>a las personas &mdash; las hace extraordinarias.&rdquo;</p>\n  <p style=\"margin:0;font-family:'Space Grotesk',Arial,sans-serif;font-size:8px;font-weight:600;color:rgba(255,170,23,0.7);letter-spacing:0.42em;text-transform:uppercase;\">&mdash;&nbsp; Victor IA</p>\n</td></tr>\n\n<!-- ══ FOOTER ══ -->\n<tr><td style=\"background:#070809;padding:26px 52px 36px;text-align:center;border-top:1px solid rgba(248,247,245,0.04);\">\n  <p style=\"margin:0 0 10px;font-family:'Space Grotesk',Arial,sans-serif;font-size:8px;font-weight:600;color:rgba(255,170,23,0.6);letter-spacing:0.38em;text-transform:uppercase;\">Victor IA</p>\n  <p style=\"margin:0 0 18px;font-family:'Space Grotesk',Arial,sans-serif;font-size:10px;color:rgba(248,247,245,0.18);line-height:1.9;\">victor-ia.com.mx &middot; info@victor-ia.com.mx &middot; +52 984 235 3159</p>\n  <p style=\"margin:0;font-family:'Space Grotesk',Arial,sans-serif;font-size:9px;color:rgba(248,247,245,0.08);\">Recibiste este correo porque interactuaste con nuestro asistente de IA.</p>\n</td></tr>\n\n</table>\n</td></tr></table>\n</body>",
        "options": {}
