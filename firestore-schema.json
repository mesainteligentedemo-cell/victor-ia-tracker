{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Victor IA Tracker — Firestore Schema v2.0",
  "description": "Comprehensive Firestore database schema for Victor IA Tracker with support for customers, usage tracking, billing, audit logs, skills inventory, and session management.",
  "version": "2.0.0",
  "lastUpdated": "2026-06-04",
  "projectId": "victor-ia-tracker",
  "collections": {
    "customers": {
      "description": "Client/customer records with billing and project associations",
      "displayName": "Customers",
      "indexes": ["status", "createdAt", "email"],
      "documents": {
        "docId": "{customerId}",
        "docIdRule": "Auto-generated UUID or custom slug (e.g., 'roes-co', 'seabird-hotel')",
        "structure": {
          "name": {
            "type": "string",
            "required": true,
            "description": "Customer full name or company name"
          },
          "email": {
            "type": "string",
            "required": true,
            "description": "Primary contact email, indexed for queries"
          },
          "phone": {
            "type": "string",
            "required": false,
            "description": "Contact phone number"
          },
          "company": {
            "type": "string",
            "required": false,
            "description": "Company name if different from customer name"
          },
          "status": {
            "type": "string",
            "enum": ["prospect", "proposal", "authorized", "active", "paused", "completed", "lost"],
            "default": "prospect",
            "description": "Customer lifecycle stage"
          },
          "type": {
            "type": "string",
            "enum": ["website", "app", "video", "branding", "consulting", "other"],
            "description": "Project type classification"
          },
          "tags": {
            "type": "array",
            "items": "string",
            "description": "Custom tags for filtering (e.g., 'luxury', 'tech-stack-react')"
          },
          "address": {
            "type": "object",
            "description": "Business address information",
            "structure": {
              "street": "string",
              "city": "string",
              "state": "string",
              "country": "string",
              "zipCode": "string"
            }
          },
          "metadata": {
            "type": "object",
            "description": "Custom fields for customer-specific data",
            "example": {
              "industry": "hospitality",
              "teamSize": 15,
              "fundingStage": "Series A"
            }
          },
          "createdAt": {
            "type": "timestamp",
            "required": true,
            "description": "Record creation timestamp (server-side)"
          },
          "updatedAt": {
            "type": "timestamp",
            "required": true,
            "description": "Last modification timestamp"
          },
          "notes": {
            "type": "string",
            "description": "Internal notes about the customer"
          }
        }
      }
    },
    "projects": {
      "description": "Project records linked to customers, tracking scope, timeline, and deliverables",
      "displayName": "Projects",
      "indexes": ["customerId", "status", "createdAt"],
      "documents": {
        "docId": "{projectId}",
        "docIdRule": "Auto-generated UUID",
        "structure": {
          "customerId": {
            "type": "reference",
            "refCollection": "customers",
            "required": true,
            "description": "Reference to parent customer"
          },
          "name": {
            "type": "string",
            "required": true,
            "description": "Project name or title"
          },
          "description": {
            "type": "string",
            "description": "Project description and objectives"
          },
          "status": {
            "type": "string",
            "enum": ["planning", "in-progress", "blocked", "review", "completed", "on-hold"],
            "default": "planning",
            "description": "Current project status"
          },
          "type": {
            "type": "string",
            "enum": ["website", "app", "video", "branding", "consulting"],
            "description": "Project type"
          },
          "budget": {
            "type": "object",
            "description": "Budget tracking",
            "structure": {
              "estimated": {
                "type": "number",
                "description": "Estimated project cost in MXN"
              },
              "actual": {
                "type": "number",
                "description": "Actual cost spent to date"
              },
              "currency": {
                "type": "string",
                "enum": ["MXN", "USD", "EUR"],
                "default": "MXN"
              }
            }
          },
          "timeline": {
            "type": "object",
            "description": "Project timeline",
            "structure": {
              "startDate": "timestamp",
              "estimatedEnd": "timestamp",
              "actualEnd": "timestamp or null"
            }
          },
          "deliverables": {
            "type": "array",
            "description": "List of project deliverables",
            "items": {
              "type": "object",
              "structure": {
                "id": "string",
                "name": "string",
                "status": "enum[pending, in-progress, completed]",
                "dueDate": "timestamp"
              }
            }
          },
          "team": {
            "type": "array",
            "description": "Team members assigned to project",
            "items": {
              "type": "object",
              "structure": {
                "role": "string",
                "allocatedHours": "number"
              }
            }
          },
          "createdAt": {
            "type": "timestamp",
            "required": true
          },
          "updatedAt": {
            "type": "timestamp",
            "required": true
          }
        }
      }
    },
    "usage": {
      "description": "API usage and activity tracking for billing and analytics",
      "displayName": "Usage Records",
      "indexes": ["customerId", "projectId", "date", "service"],
      "documents": {
        "docId": "{usageId}",
        "docIdRule": "Auto-generated UUID or composite: {customerId}_{projectId}_{date}_{service}",
        "structure": {
          "customerId": {
            "type": "reference",
            "refCollection": "customers",
            "required": true,
            "description": "Customer associated with usage"
          },
          "projectId": {
            "type": "reference",
            "refCollection": "projects",
            "required": false,
            "description": "Project associated with usage (if applicable)"
          },
          "date": {
            "type": "timestamp",
            "required": true,
            "description": "Date of usage event, indexed for daily aggregations"
          },
          "service": {
            "type": "string",
            "enum": ["elevenlabs_api", "claude_api", "stripe", "figma_api", "gsc_api", "airtable_api", "n8n_execution", "custom"],
            "required": true,
            "description": "Service that was used"
          },
          "metric": {
            "type": "string",
            "enum": ["api_calls", "tokens", "characters", "credits", "minutes", "requests"],
            "required": true,
            "description": "Type of metric being tracked"
          },
          "quantity": {
            "type": "number",
            "required": true,
            "description": "Amount of metric consumed"
          },
          "cost": {
            "type": "number",
            "description": "Cost in MXN for this usage event"
          },
          "metadata": {
            "type": "object",
            "description": "Service-specific metadata",
            "example": {
              "elevenlabs": {
                "voiceId": "iDEmt5MnqUotdwCIVplo",
                "characters": 5280,
                "cost_per_1k": 1.5
              },
              "claude_api": {
                "model": "claude-opus-4",
                "input_tokens": 2500,
                "output_tokens": 1200
              }
            }
          },
          "createdAt": {
            "type": "timestamp",
            "required": true
          }
        }
      }
    },
    "billing": {
      "description": "Billing and invoice records for customers",
      "displayName": "Billing Records",
      "indexes": ["customerId", "status", "issuedDate"],
      "documents": {
        "docId": "{invoiceId}",
        "docIdRule": "Custom format: INV-YYYY-MM-{sequence} or UUID",
        "structure": {
          "customerId": {
            "type": "reference",
            "refCollection": "customers",
            "required": true,
            "description": "Customer being billed"
          },
          "invoiceNumber": {
            "type": "string",
            "required": true,
            "description": "Unique invoice number"
          },
          "status": {
            "type": "string",
            "enum": ["draft", "sent", "viewed", "partial", "paid", "overdue", "cancelled"],
            "default": "draft",
            "description": "Invoice payment status"
          },
          "type": {
            "type": "string",
            "enum": ["project", "monthly-usage", "retainer", "one-time"],
            "description": "Type of invoice"
          },
          "items": {
            "type": "array",
            "required": true,
            "description": "Line items on invoice",
            "items": {
              "type": "object",
              "structure": {
                "description": "string",
                "quantity": "number",
                "unitPrice": "number",
                "subtotal": "number",
                "tax": "number",
                "total": "number"
              }
            }
          },
          "subtotal": {
            "type": "number",
            "required": true,
            "description": "Subtotal before tax in MXN"
          },
          "tax": {
            "type": "number",
            "description": "Tax amount (IVA) in MXN"
          },
          "total": {
            "type": "number",
            "required": true,
            "description": "Total amount due in MXN"
          },
          "currency": {
            "type": "string",
            "enum": ["MXN", "USD", "EUR"],
            "default": "MXN"
          },
          "issuedDate": {
            "type": "timestamp",
            "required": true,
            "description": "Date invoice was issued"
          },
          "dueDate": {
            "type": "timestamp",
            "required": true,
            "description": "Payment due date"
          },
          "paidDate": {
            "type": "timestamp",
            "description": "Date invoice was paid (null if unpaid)"
          },
          "paymentMethod": {
            "type": "string",
            "enum": ["bank_transfer", "credit_card", "cash", "stripe", "other"],
            "description": "Payment method used"
          },
          "notes": {
            "type": "string",
            "description": "Internal notes or payment terms"
          },
          "createdAt": {
            "type": "timestamp",
            "required": true
          },
          "updatedAt": {
            "type": "timestamp",
            "required": true
          }
        }
      }
    },
    "audit_logs": {
      "description": "Immutable audit trail for compliance and security",
      "displayName": "Audit Logs",
      "indexes": ["userId", "customerId", "action", "timestamp"],
      "documents": {
        "docId": "Auto-generated UUID (immutable)",
        "docIdRule": "UUID, never updated or deleted",
        "structure": {
          "userId": {
            "type": "string",
            "description": "User ID who performed the action"
          },
          "userName": {
            "type": "string",
            "description": "User name for readability"
          },
          "action": {
            "type": "string",
            "enum": ["create", "read", "update", "delete", "export", "login", "logout", "permission_change"],
            "required": true,
            "description": "Action performed"
          },
          "resource": {
            "type": "string",
            "enum": ["customer", "project", "invoice", "usage", "billing", "settings"],
            "required": true,
            "description": "Resource affected"
          },
          "resourceId": {
            "type": "string",
            "description": "ID of the resource affected"
          },
          "customerId": {
            "type": "reference",
            "refCollection": "customers",
            "description": "Customer context (if applicable)"
          },
          "changes": {
            "type": "object",
            "description": "Before and after values for updates",
            "example": {
              "before": { "status": "draft" },
              "after": { "status": "sent" }
            }
          },
          "ipAddress": {
            "type": "string",
            "description": "IP address of the request"
          },
          "userAgent": {
            "type": "string",
            "description": "User agent string"
          },
          "status": {
            "type": "string",
            "enum": ["success", "failure"],
            "default": "success",
            "description": "Whether action succeeded"
          },
          "errorMessage": {
            "type": "string",
            "description": "Error message if action failed"
          },
          "timestamp": {
            "type": "timestamp",
            "required": true,
            "description": "Server timestamp (immutable)"
          }
        }
      }
    },
    "skills": {
      "description": "AI skills inventory and usage tracking for the skills system",
      "displayName": "Skills",
      "indexes": ["status", "category", "lastUsedAt"],
      "documents": {
        "docId": "{skillId}",
        "docIdRule": "Slug format: brain-tracker-ux, pixel-perfecto, etc.",
        "structure": {
          "name": {
            "type": "string",
            "required": true,
            "description": "Skill display name"
          },
          "slug": {
            "type": "string",
            "required": true,
            "description": "URL-friendly identifier"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of skill capabilities"
          },
          "category": {
            "type": "string",
            "enum": ["design", "development", "content", "video", "automation", "research", "management", "other"],
            "description": "Skill category"
          },
          "status": {
            "type": "string",
            "enum": ["active", "beta", "deprecated", "archived"],
            "default": "active",
            "description": "Current status of the skill"
          },
          "icon": {
            "type": "string",
            "description": "Icon URL or emoji"
          },
          "version": {
            "type": "string",
            "description": "Semantic version (e.g., 1.0.0)"
          },
          "usageCount": {
            "type": "number",
            "default": 0,
            "description": "Total number of times skill was invoked"
          },
          "successRate": {
            "type": "number",
            "description": "Percentage of successful executions (0-100)"
          },
          "avgExecutionTime": {
            "type": "number",
            "description": "Average execution time in seconds"
          },
          "costPerExecution": {
            "type": "number",
            "description": "Estimated cost in MXN per execution"
          },
          "createdAt": {
            "type": "timestamp",
            "required": true
          },
          "updatedAt": {
            "type": "timestamp",
            "required": true
          },
          "lastUsedAt": {
            "type": "timestamp",
            "description": "Most recent invocation timestamp"
          }
        }
      }
    },
    "sessions": {
      "description": "User session records for analytics and security",
      "displayName": "Sessions",
      "indexes": ["userId", "customerId", "startedAt"],
      "documents": {
        "docId": "{sessionId}",
        "docIdRule": "UUID, generated at login",
        "structure": {
          "userId": {
            "type": "string",
            "required": true,
            "description": "Authenticated user ID"
          },
          "email": {
            "type": "string",
            "required": true,
            "description": "User email address"
          },
          "customerId": {
            "type": "reference",
            "refCollection": "customers",
            "description": "Associated customer (if user is customer-scoped)"
          },
          "role": {
            "type": "string",
            "enum": ["admin", "manager", "user", "customer", "guest"],
            "required": true,
            "description": "User role for this session"
          },
          "permissions": {
            "type": "array",
            "items": "string",
            "description": "List of granted permissions"
          },
          "startedAt": {
            "type": "timestamp",
            "required": true,
            "description": "Session start time"
          },
          "endedAt": {
            "type": "timestamp",
            "description": "Session end time (null if active)"
          },
          "expiresAt": {
            "type": "timestamp",
            "description": "Session expiration time"
          },
          "ipAddress": {
            "type": "string",
            "description": "IP address of session"
          },
          "userAgent": {
            "type": "string",
            "description": "User agent string"
          },
          "deviceType": {
            "type": "string",
            "enum": ["desktop", "mobile", "tablet"],
            "description": "Device type"
          },
          "lastActivity": {
            "type": "timestamp",
            "description": "Last recorded activity in session"
          },
          "activityCount": {
            "type": "number",
            "default": 0,
            "description": "Number of actions performed in session"
          },
          "isActive": {
            "type": "boolean",
            "default": true,
            "description": "Whether session is currently active"
          }
        }
      }
    },
    "tracker": {
      "description": "Flexible key-value store for dashboard state, settings, and temporary data (legacy support)",
      "displayName": "Tracker Data",
      "indexes": ["key", "updatedAt"],
      "documents": {
        "docId": "{key}",
        "docIdRule": "Custom keys like 'dashboard_state', 'user_settings_{userId}', etc.",
        "structure": {
          "key": {
            "type": "string",
            "required": true,
            "description": "Unique key for this data"
          },
          "data": {
            "type": "string (JSON serialized)",
            "required": true,
            "description": "Stringified JSON data (flexible schema)"
          },
          "updatedAt": {
            "type": "timestamp",
            "required": true,
            "description": "Last update timestamp"
          },
          "ttl": {
            "type": "number",
            "description": "Time-to-live in seconds (optional, for cache expiry)"
          }
        }
      }
    }
  },
  "relationships": {
    "customers_to_projects": {
      "from": "customers.id",
      "to": "projects.customerId",
      "cardinality": "1:N",
      "cascadeDelete": false,
      "description": "A customer can have multiple projects"
    },
    "customers_to_usage": {
      "from": "customers.id",
      "to": "usage.customerId",
      "cardinality": "1:N",
      "cascadeDelete": true,
      "description": "Usage records track consumption per customer"
    },
    "projects_to_usage": {
      "from": "projects.id",
      "to": "usage.projectId",
      "cardinality": "1:N",
      "cascadeDelete": true,
      "description": "Optional: link usage to specific projects"
    },
    "customers_to_billing": {
      "from": "customers.id",
      "to": "billing.customerId",
      "cardinality": "1:N",
      "cascadeDelete": false,
      "description": "Billing records are generated for customers"
    },
    "users_to_sessions": {
      "from": "users.id",
      "to": "sessions.userId",
      "cardinality": "1:N",
      "cascadeDelete": true,
      "description": "Users can have multiple active/inactive sessions"
    }
  },
  "security": {
    "rules": [
      {
        "collection": "customers",
        "rule": "Only owner or admin can read/write their own customer data",
        "example": "allow read/write if resource.data.ownerId == request.auth.uid || request.auth.token.role == 'admin'"
      },
      {
        "collection": "audit_logs",
        "rule": "Immutable, append-only. No updates or deletes allowed.",
        "example": "allow create if request.auth.token.role in ['admin', 'manager']; allow read if request.auth.token.role == 'admin'"
      },
      {
        "collection": "billing",
        "rule": "Only admin or customer can view their own invoices",
        "example": "allow read if request.auth.token.customerId == resource.data.customerId || request.auth.token.role == 'admin'"
      },
      {
        "collection": "sessions",
        "rule": "Users can only create/read their own sessions. Admin can read all.",
        "example": "allow read if request.auth.uid == resource.data.userId || request.auth.token.role == 'admin'"
      }
    ]
  },
  "migration": {
    "from": "Flat tracker collection",
    "to": "Structured multi-collection schema",
    "preserveData": true,
    "migrationSteps": [
      "Create new collections (customers, projects, usage, billing, audit_logs, skills, sessions)",
      "Map existing tracker data to appropriate collections",
      "Backfill relationships (customerId, projectId foreign keys)",
      "Validate data integrity",
      "Keep legacy 'tracker' collection for fallback",
      "Migrate billing history if applicable"
    ]
  }
}
